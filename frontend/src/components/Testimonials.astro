---
const { testimonials = [] } = Astro.props;

// If there are no real testimonials, we completely hide this section (no fake reviews allowed)
if (!testimonials || testimonials.length === 0) {
  return null;
}
---

<section class="py-24 bg-brand-bg px-4 sm:px-6 md:px-10">
  <div class="max-w-7xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-16 animate-fade-up">
      <h2 class="text-brand-primary text-3xl sm:text-4xl md:text-5xl font-bold font-serif-custom tracking-tight">
        Guest Experiences
      </h2>
      <p class="mt-4 text-brand-secondary text-base sm:text-lg">
        What our diners say about their experiences with us.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-white p-8 rounded-card border border-brand-primary/5 shadow-sm flex flex-col justify-between">
          <div>
            <div class="flex gap-1 mb-4 text-yellow-500">
              {Array.from({ length: t.rating || 5 }).map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-brand-secondary text-sm leading-relaxed mb-6 italic">
              "{t.text}"
            </p>
          </div>
          <div class="font-bold text-brand-primary border-t border-brand-primary/5 pt-4">
            — {t.author_name}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
