---
const { clientData, basePath = '' } = Astro.props;
const currentYear = new Date().getFullYear();

const mapEmbedUrl = clientData?.latitude && clientData?.longitude
  ? `https://maps.google.com/maps?q=${clientData.latitude},${clientData.longitude}&t=&z=13&ie=UTF8&iwloc=&output=embed`
  : null;
---

<footer class="bg-brand-primary text-brand-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-10 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div class="relative">
        <h2 class="text-2xl sm:text-3xl font-bold font-serif-custom tracking-tight mb-4">
          {clientData?.business_name || 'Restaurant'}
        </h2>
        <p class="text-brand-bg/70 text-sm leading-relaxed mb-6 max-w-xs">
          Experience exquisite flavor and authentic hospitality. Join us for an unforgettable dining experience.
        </p>
        <div class="flex items-center gap-3">
          {clientData?.facebook_url && (
            <a href={clientData.facebook_url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-brand-bg/10 hover:bg-brand-bg/20 flex items-center justify-center transition-colors" aria-label="Facebook">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
            </a>
          )}
          {clientData?.instagram_url && (
            <a href={clientData.instagram_url} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-brand-bg/10 hover:bg-brand-bg/20 flex items-center justify-center transition-colors" aria-label="Instagram">
              <svg class="w-5 h-5 fill-none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          )}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold font-serif-custom mb-4">Quick Links</h3>
        <nav class="flex flex-col gap-3 text-sm">
          <a href={`${basePath}/`} class="text-brand-bg/70 hover:text-brand-bg transition-colors">Home</a>
          <a href={`${basePath}/about`} class="text-brand-bg/70 hover:text-brand-bg transition-colors">About Us</a>
          <a href={`${basePath}/menu`} class="text-brand-bg/70 hover:text-brand-bg transition-colors">Menu</a>
          <a href={`${basePath}/gallery`} class="text-brand-bg/70 hover:text-brand-bg transition-colors">Gallery</a>
          <a href={`${basePath}/contact`} class="text-brand-bg/70 hover:text-brand-bg transition-colors">Contact</a>
        </nav>
      </div>

      <div>
        <h3 class="text-lg font-semibold font-serif-custom mb-4">Contact Us</h3>
        <address class="not-italic space-y-3 text-sm text-brand-bg/70">
          {clientData?.address && (
            <p>{clientData.address}{clientData.city ? `, ${clientData.city}` : ''}{clientData.state ? `, ${clientData.state}` : ''}</p>
          )}
          {clientData?.phone && (
            <p>
              <a href={`tel:${clientData.phone}`} class="hover:text-brand-bg transition-colors">
                {clientData.phone}
              </a>
            </p>
          )}
          {clientData?.email && (
            <p>
              <a href={`mailto:${clientData.email}`} class="hover:text-brand-bg transition-colors">
                {clientData.email}
              </a>
            </p>
          )}
        </address>
        {mapEmbedUrl && (
          <div class="mt-4 rounded-card overflow-hidden border border-brand-bg/10 h-[200px]">
            <iframe
              title="Restaurant Location"
              class="w-full h-full border-0 grayscale contrast-115"
              src={mapEmbedUrl}
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        )}
      </div>

      <div>
        <h3 class="text-lg font-semibold font-serif-custom mb-4">Opening Hours</h3>
        <div class="space-y-2 text-sm text-brand-bg/70">
          <div class="flex justify-between">
            <span>Mon - Thu</span>
            <span class="text-brand-bg">12:00 - 23:00</span>
          </div>
          <div class="flex justify-between">
            <span>Fri - Sat</span>
            <span class="text-brand-bg">12:00 - 23:30</span>
          </div>
          <div class="flex justify-between">
            <span>Sunday</span>
            <span class="text-brand-bg">12:00 - 22:30</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-brand-bg/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-brand-bg/50">
      <p>&copy; {currentYear} {clientData?.business_name || 'Restaurant'}. All rights reserved.</p>
      <nav class="flex gap-6">
        <a href="#" class="hover:text-brand-bg transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-brand-bg transition-colors">Terms of Service</a>
      </nav>
    </div>
  </div>
</footer>
