---
const { clientData, menuItems = [] } = Astro.props;
const slug = clientData?.slug || "";
const phone = (clientData?.phone || "").replace(/[^0-9]/g, "");
---

<section id="order-online" class="py-24 bg-brand-bg px-4 sm:px-6 md:px-10">
  <div class="max-w-7xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2
        class="text-brand-primary text-3xl sm:text-4xl md:text-5xl font-bold font-serif-custom tracking-tight"
      >
        Order Online
      </h2>
      <p class="mt-4 text-brand-secondary text-base sm:text-lg">
        Select your favorites and we'll prepare them fresh for you.
      </p>
    </div>

    {
      menuItems.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-brand-secondary text-lg">
            No menu items available right now. Please check back later.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <div
            id="menu-items-container"
            class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6"
          >
            {menuItems.map((item) => (
              <div class="bg-white rounded-card overflow-hidden shadow-md flex hover:shadow-lg transition-shadow">
                <div class="w-1/3 h-32 overflow-hidden">
                  <img
                    src={
                      item.image_url ||
                      "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=400&q=80"
                    }
                    alt={item.name}
                    class="w-full h-full object-cover"
                  />
                </div>
                <div class="p-4 flex-1 flex flex-col justify-between">
                  <div>
                    <h3 class="text-brand-primary font-bold font-serif-custom">
                      {item.name}
                    </h3>
                    <p class="text-brand-secondary text-xs mt-1 line-clamp-2">
                      {item.description}
                    </p>
                  </div>
                  <div class="flex items-center justify-between mt-3">
                    <span class="text-brand-primary font-bold">
                       ${item.price}
                    </span>
                    <button
                      data-name={item.name}
                      data-price={item.price}
                      class="add-to-cart-btn bg-brand-primary text-brand-bg text-xs font-semibold px-3 py-1.5 rounded-btn hover:opacity-90 transition-colors"
                    >
                      Add
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="bg-white rounded-card border border-brand-primary/5 shadow-md p-6 h-fit sticky top-24">
            <h3 class="text-brand-primary text-xl font-bold font-serif-custom mb-4">
              Your Order
            </h3>
            <div
              id="cart-items"
              class="space-y-3 mb-4 max-h-64 overflow-y-auto"
            >
              <p class="text-brand-secondary text-sm text-center py-4">
                Your cart is empty
              </p>
            </div>
            <div class="border-t border-brand-primary/10 pt-4">
              <div class="flex justify-between items-center mb-4">
                <span class="text-brand-primary font-bold">Total</span>
                <span
                  id="cart-total"
                  class="text-brand-primary text-xl font-bold"
                >
                  $ 0
                </span>
              </div>
              <a
                id="whatsapp-btn"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="w-full bg-green-600 text-white font-semibold py-3 rounded-btn flex items-center justify-center gap-2 hover:bg-green-700 transition-colors opacity-50 cursor-not-allowed"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
                Order via WhatsApp
              </a>
            </div>
          </div>
        </div>
      )
    }
  </div>
</section>

<script>
  let cart = [];
  const phone = "{phone}";
  const menuContainer = document.getElementById("menu-items-container");
  const cartItemsEl = document.getElementById("cart-items");
  const cartTotalEl = document.getElementById("cart-total");
  const whatsappBtn = document.getElementById("whatsapp-btn");

  if (menuContainer) {
    menuContainer.addEventListener("click", (e) => {
      const btn = e.target.closest(".add-to-cart-btn");
      if (!btn) return;
      const name = btn.dataset.name;
      const price = parseInt(btn.dataset.price, 10);
      if (!name || isNaN(price)) return;

      const existing = cart.find((item) => item.name === name);
      if (existing) {
        existing.quantity++;
      } else {
        cart.push({ name, price, quantity: 1 });
      }
      updateCart();
    });
  }

  if (cartItemsEl) {
    cartItemsEl.addEventListener("click", (e) => {
      const btn = e.target.closest(".remove-from-cart-btn");
      if (!btn) return;
      const name = btn.dataset.name;
      if (!name) return;
      removeFromCart(name);
    });
  }

  function removeFromCart(name) {
    cart = cart.filter((item) => item.name !== name);
    updateCart();
  }

  function updateCart() {
    if (!cartItemsEl || !cartTotalEl || !whatsappBtn) return;

    if (cart.length === 0) {
      cartItemsEl.innerHTML =
        '<p class="text-brand-secondary text-sm text-center py-4">Your cart is empty</p>';
      cartTotalEl.innerText = "$ 0";
      whatsappBtn.classList.add("opacity-50", "cursor-not-allowed");
      whatsappBtn.removeAttribute("href");
      return;
    }

    let html = "";
    let total = 0;
    cart.forEach((item) => {
      const itemTotal = item.price * item.quantity;
      total += itemTotal;
      html += `
        <div class="flex justify-between items-center text-sm">
          <div class="flex-1">
            <p class="text-brand-primary font-medium">${item.name}</p>
            <p class="text-brand-secondary text-xs">$${item.price} x ${item.quantity}</p>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-brand-primary font-bold text-xs">$${itemTotal}</span>
            <button data-name="${item.name}" class="remove-from-cart-btn text-red-500 hover:text-red-700 text-xs">Remove</button>
          </div>
        </div>
      `;
    });

    cartItemsEl.innerHTML = html;
    cartTotalEl.innerText = `$${total}`;

    const message = cart
      .map(
        (item) =>
          `- ${item.name} x${item.quantity}: $${item.price * item.quantity}`,
      )
      .join("%0A");
    const fullMessage = message + `%0A%0ATotal: $${total}`;
    whatsappBtn.href = `https://wa.me/${phone}?text=${fullMessage}`;
    whatsappBtn.classList.remove("opacity-50", "cursor-not-allowed");
  }
</script>
