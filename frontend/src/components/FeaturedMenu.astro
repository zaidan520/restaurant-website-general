---
const { clientData, menuItems = [], basePath = '' } = Astro.props;
const slug = clientData?.slug || '';

const fallbackItems = [
  { name: "Signature Dish", description: "Chef's special preparation using fresh local ingredients.", price: "1200", image_url: "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=400&q=80" },
  { name: "House Speciality", description: "Traditional recipe passed down through generations.", price: "1500", image_url: "https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=400&q=80" },
  { name: "Gourmet Selection", description: "Exquisite flavors combined to create a memorable taste.", price: "1850", image_url: "https://images.unsplash.com/photo-1482049016688-2d3e1b311543?auto=format&fit=crop&w=400&q=80" }
];

const itemsToShow = menuItems.length > 0 ? menuItems.slice(0, 3) : fallbackItems;
---

<section class="py-24 bg-brand-bg px-4 sm:px-6 md:px-10">
  <div class="max-w-7xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-16 animate-fade-up">
      <h2 class="text-brand-primary text-3xl sm:text-4xl md:text-5xl font-bold font-serif-custom tracking-tight">
        Featured Specialties
      </h2>
      <p class="mt-4 text-brand-secondary text-base sm:text-lg">
        Taste our handpicked favorites, crafted with fresh seasonal ingredients.
      </p>
    </div>

    <!-- Items Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {itemsToShow.map((item, index) => (
        <div class="bg-white rounded-card overflow-hidden shadow-md transition-all duration-300 hover:-translate-y-2 hover:shadow-xl group">
          <div class="h-64 overflow-hidden relative">
            <img 
              src={item.image_url || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=400&q=80'} 
              alt={item.name} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute top-4 right-4 bg-brand-primary text-brand-bg text-sm font-semibold px-4 py-1.5 rounded-full shadow-md">
              $ {item.price}
            </div>
          </div>
          <div class="p-8">
            <h3 class="text-brand-primary text-xl font-bold font-serif-custom mb-3">
              {item.name}
            </h3>
            <p class="text-brand-secondary text-sm leading-relaxed mb-4">
              {item.description}
            </p>
            <a 
              href={`${basePath}/order_now?item=${encodeURIComponent(item.name)}&price=${item.price}`}
              class="inline-flex items-center gap-1.5 bg-green-600 text-white text-sm font-semibold px-5 py-2.5 rounded-btn hover:bg-green-700 transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Order Now
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Menu Button -->
    <div class="mt-16 text-center">
      <a href={`${basePath}/menu`} class="inline-block bg-transparent hover:bg-brand-primary/5 text-brand-primary font-semibold px-8 py-3.5 rounded-btn border-2 border-brand-primary transition-all">
        View Full Menu
      </a>
    </div>
  </div>
</section>
