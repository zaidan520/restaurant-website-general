---
const { src, className = "absolute inset-0 w-full h-full" } = Astro.props;
---

<div class={`boomerang-video-bg ${className}`} data-src={src}>
  <video
    class="w-full h-full object-cover main-video"
    src={src}
    muted
    playsinline
    preload="auto"
    crossorigin="anonymous"
  ></video>
  <canvas
    class="w-full h-full object-cover display-canvas hidden"
  ></canvas>
</div>

<script>
  class BoomerangVideoBg {
    constructor(element) {
      this.container = element;
      this.src = element.dataset.src;
      this.video = element.querySelector('.main-video');
      this.canvas = element.querySelector('.display-canvas');
      this.ctx = this.canvas.getContext('2d');
      this.frames = [];
      this.capturing = true;
      this.lastTime = -1;
      this.MAX_WIDTH = 960;
      this.framesReady = false;
      
      this.init();
    }
    
    init() {
      const onLoaded = () => {
        this.video.play().catch(() => {});
        this.requestFrameLoop();
      };
      
      const onEnded = () => {
        this.capturing = false;
        if (this.frames.length > 0) {
          this.framesReady = true;
          this.video.style.display = 'none';
          this.canvas.classList.remove('hidden');
          this.startPlayback();
        }
      };
      
      this.video.addEventListener('loadedmetadata', onLoaded);
      this.video.addEventListener('ended', onEnded);
      if (this.video.readyState >= 1) {
        onLoaded();
      }
    }
    
    captureFrame() {
      if (!this.capturing || this.video.readyState < 2) return;
      if (this.video.currentTime === this.lastTime) return;
      this.lastTime = this.video.currentTime;
      
      const vw = this.video.videoWidth;
      const vh = this.video.videoHeight;
      if (!vw || !vh) return;
      
      const scale = Math.min(1, this.MAX_WIDTH / vw);
      const w = Math.round(vw * scale);
      const h = Math.round(vh * scale);
      
      const canvas = document.createElement('canvas');
      canvas.width = w;
      canvas.height = h;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      ctx.drawImage(this.video, 0, 0, w, h);
      this.frames.push(canvas);
    }
    
    requestFrameLoop() {
      if (!this.capturing) return;
      this.captureFrame();
      requestAnimationFrame(() => this.requestFrameLoop());
    }
    
    startPlayback() {
      if (this.frames.length === 0) return;
      
      const first = this.frames[0];
      this.canvas.width = first.width;
      this.canvas.height = first.height;
      
      let index = 0;
      let direction = 1;
      let last = performance.now();
      const interval = 1000 / 30; // 30 FPS
      
      const render = (now) => {
        if (now - last >= interval) {
          last = now;
          this.ctx.drawImage(this.frames[index], 0, 0);
          index += direction;
          if (index >= this.frames.length - 1) {
            index = this.frames.length - 1;
            direction = -1;
          } else if (index <= 0) {
            index = 0;
            direction = 1;
          }
        }
        requestAnimationFrame(render);
      };
      
      requestAnimationFrame(render);
    }
  }

  // Initialize all boomerang background videos
  document.querySelectorAll('.boomerang-video-bg').forEach(el => {
    new BoomerangVideoBg(el);
  });
</script>
