---
const { clientData, hours = [], basePath = '' } = Astro.props;

const dayNames = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];

// Build default hours array if empty
const displayHours = hours.length === 7 
  ? hours 
  : Array.from({ length: 7 }, (_, i) => ({
      day_of_week: i,
      open_time: "12:00",
      close_time: "23:00",
      is_closed: false
    }));
---

<section class="py-24 bg-brand-bg px-4 sm:px-6 md:px-10">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
    
    <!-- Left Column: Contact info -->
    <div class="space-y-8 animate-fade-up">
      <h2 class="text-brand-primary text-3xl sm:text-4xl md:text-5xl font-bold font-serif-custom tracking-tight">
        Get in Touch
      </h2>
      <p class="text-brand-secondary text-base leading-relaxed max-w-md">
        Have questions about our dishes, hosting private events, or planning catering? Reach out directly.
      </p>
      
      <div class="space-y-6 pt-4">
        {clientData?.address && (
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-brand-primary/5 text-brand-primary flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h4 class="text-brand-primary font-bold text-sm">Location</h4>
              <p class="text-brand-secondary text-sm mt-1">
                {clientData.address}{clientData.city ? `, ${clientData.city}` : ''}{clientData.state ? `, ${clientData.state}` : ''}
              </p>
            </div>
          </div>
        )}
        
        {clientData?.phone && (
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-brand-primary/5 text-brand-primary flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <h4 class="text-brand-primary font-bold text-sm">Phone</h4>
              <a href={`tel:${clientData.phone}`} class="text-brand-secondary text-sm mt-1 block hover:text-brand-accent transition-colors">
                {clientData.phone}
              </a>
            </div>
          </div>
        )}

        {clientData?.email && (
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-brand-primary/5 text-brand-primary flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h4 class="text-brand-primary font-bold text-sm">Email</h4>
              <a href={`mailto:${clientData.email}`} class="text-brand-secondary text-sm mt-1 block hover:text-brand-accent transition-colors">
                {clientData.email}
              </a>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Right Column: Opening Hours -->
    <div class="bg-white p-8 sm:p-10 rounded-card border border-brand-primary/5 shadow-md animate-fade-up delay-100">
      <h3 class="text-brand-primary text-2xl font-bold font-serif-custom mb-6">
        Opening Hours
      </h3>
      <div class="space-y-3">
        {dayNames.map((day, idx) => {
          const hourRecord = displayHours.find((h) => h.day_of_week === idx);
          const isClosed = !hourRecord || hourRecord.is_closed;
          const timeText = isClosed 
            ? "Closed" 
            : `${hourRecord.open_time || "12:00"} - ${hourRecord.close_time || "23:00"}`;
            
          return (
            <div class="flex justify-between py-2.5 border-b border-brand-primary/5 text-sm">
              <span class="font-semibold text-brand-primary">{day}</span>
              <span class={isClosed ? "text-red-500 font-medium" : "text-brand-secondary"}>
                {timeText}
              </span>
            </div>
          );
        })}
      </div>
    </div>

  </div>
</section>
