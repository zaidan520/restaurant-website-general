---
import Layout from '../layouts/Layout.astro';
---

<Layout pageTitle="Restaurant Not Found - 404">
  <div class="h-screen w-full flex flex-col justify-center items-center bg-[#fdfbf7] text-[#1f2a1d] px-4 text-center">
    <h1 class="text-6xl font-bold font-serif-custom mb-4">404</h1>
    <h2 class="text-2xl font-semibold mb-6">Restaurant Not Found</h2>
    <p class="text-[#4b5b47] max-w-md mb-8">The restaurant website you are trying to access does not exist or has not been registered on our platform yet.</p>
  </div>
</Layout>
