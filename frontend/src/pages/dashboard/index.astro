---
import Layout from '../../layouts/Layout.astro';
const API_BASE = 'http://localhost:8000/api';
let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const username = formData.get('username');
  const password = formData.get('password');
  if (username === 'admin' && password === 'admin123') {
    return Astro.redirect('/dashboard/home');
  }
}
---

<Layout pageTitle="Login" pageDescription="Admin login">
  <div class="bg-gray-50 min-h-screen flex items-center justify-center">
    <div class="max-w-sm w-full mx-auto px-6">
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
        <h1 class="text-2xl font-bold text-center mb-6">Admin Login</h1>
        {error && <div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg">{error}</div>}
        <form method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
            <input type="text" name="username" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-600 focus:border-transparent outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input type="password" name="password" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-600 focus:border-transparent outline-none" />
          </div>
          <button type="submit" class="w-full bg-green-700 hover:bg-green-800 text-white font-semibold py-2.5 px-6 rounded-full transition-colors">
            Login
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
