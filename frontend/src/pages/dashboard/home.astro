---
import Layout from "../../layouts/Layout.astro";
const API_BASE = "http://localhost:8000/api";

let clients = [];
let selectedSlug = "";
let orders = [];
let menuItems = [];
let menuCategories = [];
let reservations = [];
let clientData = null;
let createError = "";
let isPost = false;

if (Astro.request.method === "POST") {
  isPost = true;
  const formData = await Astro.request.formData();
  const business_name = formData.get("business_name")?.toString().trim();
  const phone = formData.get("phone")?.toString().trim();
  const city = formData.get("city")?.toString().trim();
  const address = formData.get("address")?.toString().trim();

  if (!business_name) {
    createError = "Business name required";
  } else {
    try {
      const res = await fetch(`${API_BASE}/clients/register`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ business_name, phone, city, address }),
      });
      const data = await res.json();
      if (data.success && data.slug) {
        return Astro.redirect(`/dashboard/home?slug=${data.slug}`);
      } else {
        createError = data.detail || "Failed to create restaurant";
      }
    } catch (e) {
      createError = "Failed";
    }
  }
}

if (!isPost || (isPost && !createError)) {
  try {
    const res = await fetch(`${API_BASE}/clients/`);
    if (res.ok) {
      clients = await res.json();
      if (clients.length > 0 && !selectedSlug) {
        selectedSlug = clients[0].slug;
      }
    }
  } catch (e) {
    console.error("Failed to load clients", e);
  }
}

if (selectedSlug) {
  try {
    const [clientRes, ordersRes, menuRes, reservationsRes] = await Promise.all([
      fetch(`${API_BASE}/clients/${selectedSlug}`),
      fetch(`${API_BASE}/orders/${selectedSlug}`),
      fetch(`${API_BASE}/menu/${selectedSlug}`),
      fetch(`${API_BASE}/reservations/${selectedSlug}`),
    ]);

    if (clientRes.ok) clientData = await clientRes.json();
    if (ordersRes.ok) orders = await ordersRes.json();
    if (menuRes.ok) {
      const menuData = await menuRes.json();
      menuCategories = menuData;
      menuItems = menuData.flatMap((c) => c.items || []);
    }
    if (reservationsRes.ok) reservations = await reservationsRes.json();
  } catch (e) {
    console.error("Failed to load data", e);
  }
}
