                  >Order</th
                >
                <th
                  class="px-4 py-2 text-left text-xs font-medium text-gray-600"
                  >Customer</th
                >
                <th
                  class="px-4 py-2 text-left text-xs font-medium text-gray-600"
                  >Phone</th
                >
                <th
                  class="px-4 py-2 text-left text-xs font-medium text-gray-600"
                  >Total</th
                >
                <th
                  class="px-4 py-2 text-left text-xs font-medium text-gray-600"
                  >Status</th
                >
                <th
                  class="px-4 py-2 text-right text-xs font-medium text-gray-600"
                  >Action</th
