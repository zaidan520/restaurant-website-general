          <div class="grid grid-cols-2 gap-4">
            <div class="bg-gray-50 rounded-xl p-4">
              <div class="text-sm text-gray-600 mb-1">Total Orders</div>
              <div class="text-2xl font-bold text-gray-900">
                {orders.length}
